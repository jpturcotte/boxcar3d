{
  "name": "boxcar3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Evolving 3D vehicles in a corridor world — a genetic algorithm sandbox inspired by BoxCar2D.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:determinism": "vitest run tests/evaluation-determinism.test.js tests/evaluation-golden.test.js tests/cohort-determinism.test.js tests/population-determinism.test.js tests/evolution-operators.test.js",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "probe:s1": "node tests/s1-calibration-probe.js",
    "probe:timing": "node scripts/probe-rapier-timing.js",
    "probe:population": "node scripts/characterize-population.js",
    "probe:physics-explosion": "node scripts/probe-physics-explosion.js",
    "probe:integrity": "node scripts/probe-integrity.js",
    "probe:package-smoke": "node scripts/probe-rapier-package-smoke.js",
    "bench:physics": "node scripts/bench-physics.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "@dimforge/rapier3d-deterministic-compat": "0.19.3",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@vitest/browser": "3.2.7",
    "eslint": "^9.0.0",
    "playwright": "1.61.1",
    "vite": "^7.0.0",
    "vitest": "3.2.7"
  }
}
